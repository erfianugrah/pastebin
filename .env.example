# Pasteriser local .env -- copy to .env and fill in values
# .env is git-ignored. Never commit secrets.

# ---- Supabase ----

# Project URL (visible, not sensitive)
SUPABASE_URL=https://dewddkcmwrzbpynylyhg.supabase.co

# Secret key for direct DB access -- bypasses RLS, never expose to clients.
# Two formats accepted by supabase-js:
#   1. New format `sb_secret_...` (recommended) -- only shown ONCE at creation.
#      Find/create at: Dashboard → Settings → API Keys. If lost, rotate.
#   2. Legacy `service_role` JWT -- always visible via
#      `supabase projects api-keys --project-ref <ref>`. Same permissions but
#      based on the JWT secret; Supabase recommends migrating off it.
SUPABASE_SECRET_KEY=

# Publishable key (sb_publishable_...) -- safe to expose, used for RLS testing.
# Visible via the CLI or Dashboard at any time.
SUPABASE_PUBLISHABLE_KEY=

# Direct DB connection string for pgcli (session pooler)
# Format: postgresql://postgres.<ref>:<password>@aws-1-eu-central-1.pooler.supabase.com:5432/postgres
PASTERISER_DB_URL=

# ---- Smoke test ----

# Where to run smoke tests against
# Production: https://paste.erfi.io (default)
# Local dev:  http://localhost:8787
PASTE_API_URL=https://paste.erfi.io
