---
import Layout from '../../../layouts/Layout.astro';
import DeletePaste from '../../../components/DeletePaste';

// Static path for Astro build; Cloudflare Worker routes all /pastes/:id/delete here
export function getStaticPaths() {
	return [{ params: { id: 'index' } }];
}
---

<Layout title="Delete Paste - Pasteriser">
	<div class="max-w-4xl mx-auto px-4 py-8">
		<DeletePaste client:load />
	</div>
</Layout>
