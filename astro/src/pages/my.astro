---
import Layout from '../layouts/Layout.astro';
import MyPastes from '../components/MyPastes';
---

<Layout title="My Pastes - Pasteriser">
	<div class="max-w-5xl mx-auto px-4 py-4">
		<div class="mb-3 pb-2 border-b border-border-strong">
			<h1 class="text-2xl leading-tight font-bold">My pastes</h1>
			<p class="text-xs text-muted-foreground mt-1">Pastes you created while signed in.</p>
		</div>
		<MyPastes client:load />
	</div>
</Layout>
