---
import Layout from '../layouts/Layout.astro';
import MyPastes from '../components/MyPastes';
---

<Layout title="My Pastes - Pasteriser">
  <div class="max-w-4xl mx-auto px-4 py-8">
    <div class="mb-6">
      <h1 class="text-2xl font-bold tracking-tight">My Pastes</h1>
      <p class="text-sm text-muted-foreground mt-1">Pastes you create while signed in.</p>
    </div>
    <MyPastes client:load />
  </div>
</Layout>
