# Astro public env vars (PUBLIC_ prefix exposes them to the browser bundle).
# Copy to astro/.env to enable the live recent feed (Realtime subscriptions).
# Without these set, the feed gracefully falls back to polling.

PUBLIC_API_URL=https://paste.erfi.dev

PUBLIC_SUPABASE_URL=https://dewddkcmwrzbpynylyhg.supabase.co
# Publishable key only -- never put the secret key here.
PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
