# Astro public env vars (PUBLIC_ prefix exposes them to the browser bundle).
# Copy to astro/.env if you want to override defaults.
#
# Pasteriser uses the BFF pattern: every Supabase call goes through the
# Cloudflare Worker, never browser-direct. Therefore no Supabase URL or
# publishable key is needed in the browser bundle.

PUBLIC_API_URL=https://paste.erfi.io
