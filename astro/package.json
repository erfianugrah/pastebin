{
  "name": "pasteriser-ui",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "npm run update-prism && astro dev",
    "start": "npm run update-prism && astro dev",
    "build": "npm run update-prism && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "update-prism": "mkdir -p public/prism-components && cp -r node_modules/prismjs/components/* public/prism-components/",
    "deploy": "npm run update-prism && astro build",
    "deploy:full": "npm run update-prism && astro build"
  },
  "dependencies": {
    "@astrojs/react": "^5.0.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/iosevka": "^5.2.5",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/typography": "^0.5.19",
    "astro": "^6.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.563.0",
    "prismjs": "^1.30.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.17",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1",
    "zod": "^4.3.6"
  },
