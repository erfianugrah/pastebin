{
	"name": "pasteriser",
	"version": "0.0.0",
	"private": true,
	"scripts": {
		"deploy": "bun run build:ui && wrangler deploy",
		"deploy:prod": "bun run build:ui && wrangler deploy --env production",
		"dev": "wrangler dev",
		"dev:ui": "cd astro && bun run dev -- --port 3000",
		"dev:all": "concurrently \"bun run dev:ui\" \"bun run dev\"",
		"start": "bun run dev:all",
		"build:ui": "cd astro && bun run build",
		"build": "bun run build:ui && wrangler build",
		"publish": "bun run build && bun run deploy",
		"cf-typegen": "wrangler types",
		"test": "vitest run",
		"test:ui": "cd astro && bunx vitest run",
		"test:e2e": "bunx playwright test --project=chromium-prod",
		"test:e2e:local": "bunx playwright test --project=chromium-local",
		"test:smoke": "tsx scripts/smoke-test.ts",
		"test:race": "tsx scripts/concurrent-burn-test.ts",
		"test:rls": "tsx scripts/verify-rls.ts",
		"test:all-live": "tsx scripts/run-all-live-tests.ts",
		"test:smoke:tail": "tsx scripts/with-wrangler-tail.ts -- tsx scripts/smoke-test.ts",
		"test:race:tail": "tsx scripts/with-wrangler-tail.ts -- tsx scripts/concurrent-burn-test.ts",
		"test:rls:tail": "tsx scripts/with-wrangler-tail.ts -- tsx scripts/verify-rls.ts",
		"test:all-live:tail": "tsx scripts/with-wrangler-tail.ts -- tsx scripts/run-all-live-tests.ts",
		"test:e2e:tail": "tsx scripts/with-wrangler-tail.ts -- bunx playwright test",
		"test:all": "bun run test && bun run test:ui && bun run test:e2e",
		"test:watch": "vitest",
		"lint": "eslint --ext .ts ./src",
		"check": "tsc --noEmit",
		"check:migrations": "tsx scripts/check-migrations-grants.ts"
	},
	"dependencies": {
		"@astrojs/check": "^0.9.2",
		"@supabase/supabase-js": "^2.103.0",
		"hono": "^4.12.8",
		"pg": ">=8.16.3",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20260206.0",
		"@playwright/test": "^1.58.2",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "^25.2.1",
		"@types/pg": "^8.20.0",
		"@typescript-eslint/eslint-plugin": "^8.54.0",
		"@typescript-eslint/parser": "^8.54.0",
		"concurrently": "^9.1.2",
		"eslint": "^9.39.2",
		"jsdom": "^29.0.0",
		"playwright": "^1.58.2",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vitest": "^4.0.18",
		"wrangler": "^4.63.0"
	}
}
